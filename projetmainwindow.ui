}*/
QPushButton {
    background-color: #FFAE9D; /* Fond rose */
    color: #392E2C; /* Texte foncé pour contraste */
    border: 2px solid #CCAEA4; /* Bordure douce en couleur taupe */
    border-radius: 10px; /* Coins arrondis */
    padding: 5px 5px;
    font-size: 16px;
}

QPushButton:hover {
    background-color: #B39188; /* Fond taupe au survol */
    border-color: #FFAE9D; /* Bordure rose au survol */
}

QPushButton:pressed {
    background-color: #392E2C; /* Fond foncé au clic */
    color: #FAF2EA; /* Texte clair */
    border-color: #B39188; /* Bordure taupe au clic */
}</string>
