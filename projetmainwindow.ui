     <property name="styleSheet">
      <string notr="true">/*QPushButton {color:#FAF2EA;
background:#B39188; 
border-radius:15px ;

}

QPushButton:hover {
    background-color: #CCAEA4;  /* Quand la souris passe dessus */
/*}

QPushButton:pressed {
